# Copy this file to .env and fill in your credentials

# Flask
FLASK_SECRET_KEY=your-super-secret-key-change-this

# Firebase Admin SDK (path to your downloaded serviceAccountKey.json)
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Firebase Web Config (from Firebase Console > Project Settings > Your Apps)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Gemini AI API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
